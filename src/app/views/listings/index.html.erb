<p id="notice"><%= notice %></p>

<div class="d-flex justify-content-center mb-2">
  <%= form_tag(listings_path, method: :get) do %>
    <%= text_field_tag(:search, params[:search], placeholder: 'Search by hobby...') %>
    <%= collection_select(:city, params[:city], City.all, :id, :name, prompt: "Location...") %>
    <%= submit_tag("Search", class: "btn btn-info") %>
  <% end %>
</div>

<div class="container-fluid">
  <div class="container">
    <h2 class="text-center">Listings</h2>
    <div class="row" id="listings-container">
      <%= render "listing_cards", listings: @listings %>
    </div>

    <%# Desktop pagination — hidden on mobile %>
    <div class="d-none d-md-flex justify-content-center mt-4 pagination-desktop">
      <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
    </div>

    <%# Mobile load-more / infinite scroll — hidden on desktop %>
    <div class="d-md-none" id="load-more-section">
      <% if @pagy.next %>
        <div class="text-center my-4">
          <%= link_to "Load More",
                listings_path(search: params[:search], city: params[:city], page: @pagy.next),
                id: "load-more-btn",
                class: "btn btn-outline-info btn-lg px-5",
                data: { remote: true } %>
        </div>
        <div id="load-more-sentinel"></div>
      <% else %>
        <p class="text-center text-muted my-4">All listings loaded.</p>
      <% end %>
    </div>
  </div>
</div>
